{
  "name": "mfe-bank-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start:shell": "webpack serve --config webpack.shell.config.js --mode development",
    "start:accounts": "webpack serve --config webpack.accounts.config.js --mode development",
    "start:transactions": "webpack serve --config webpack.transactions.config.js --mode development",
    "start:profile": "webpack serve --config webpack.profile.config.js --mode development",
    "build:shell": "webpack --config webpack.shell.config.js --mode production",
    "build:accounts": "webpack --config webpack.accounts.config.js --mode production",
    "build:transactions": "webpack --config webpack.transactions.config.js --mode production",
    "build:profile": "webpack --config webpack.profile.config.js --mode production",
    "build": "npm run build:shell && npm run build:accounts && npm run build:transactions && npm run build:profile"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^6.0.0",
    "@supabase/supabase-js": "^2.0.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "webpack": "^5.0.0",
    "webpack-cli": "^5.0.0",
    "webpack-dev-server": "^4.0.0",
    "ts-loader": "^9.0.0",
    "html-webpack-plugin": "^5.0.0",
    "style-loader": "^3.0.0",
    "css-loader": "^6.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@types/node": "^20.0.0"
  }
}
